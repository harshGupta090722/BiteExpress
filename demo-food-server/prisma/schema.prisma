// Prisma schema for the single-restaurant food ordering app.
// Roles: CUSTOMER (guest by default), STAFF (manage orders), ADMIN (revenue + everything).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PROCESSING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]
  actedEvents OrderEvent[] @relation("EventActor")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String
  rate        Float
  category    String
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String?
  product       String
  quantity      Int
  price         Float
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Null for guest checkout orders.
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  events OrderEvent[]

  @@index([status])
  @@index([createdAt])
}

model OrderEvent {
  id         String       @id @default(cuid())
  type       String // ORDER_CREATED | STATUS_CHANGED | NOTE_ADDED
  message    String
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  actorName  String?
  createdAt  DateTime     @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("EventActor", fields: [actorId], references: [id])

  @@index([orderId])
}
