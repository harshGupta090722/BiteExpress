NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/food_delivery?schema=public"

# Redis for GraphQL subscriptions
REDIS_HOST=localhost
REDIS_PORT=6379

# Must match AUTH_SHARED_SECRET in the Next.js app
AUTH_SHARED_SECRET=

# Must match SERVICE_TOKEN in the Next.js app
SERVICE_TOKEN=

# Comma-separated emails auto-promoted on first login
ADMIN_EMAILS=you@example.com
STAFF_EMAILS=staff@example.com

# Optional: Slack Incoming Webhook URL for order alerts
SLACK_WEBHOOK_URL=

# Allowed CORS origins (comma separated)
CORS_ORIGIN=http://localhost:3000
